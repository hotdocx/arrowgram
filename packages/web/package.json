{
    "name": "@hotdocx/arrowgram-web",
    "version": "1.0.0",
    "type": "module",
    "description": "Embeddable Arrowgram workspace, paper editor, preview components, and adapters.",
    "license": "MIT",
    "homepage": "https://github.com/hotdocx/arrowgram/tree/main/packages/web",
    "bugs": {
        "url": "https://github.com/hotdocx/arrowgram/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hotdocx/arrowgram.git",
        "directory": "packages/web"
    },
    "sideEffects": [
        "**/*.css"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./preview": {
            "types": "./dist/preview/index.d.ts",
            "import": "./dist/preview.js"
        },
        "./adapters": {
            "types": "./dist/adapters/index.d.ts",
            "import": "./dist/adapters.js"
        },
        "./embed": {
            "types": "./dist/embed/index.d.ts",
            "import": "./dist/embed.js"
        },
        "./ai": {
            "types": "./dist/ai/index.d.ts",
            "import": "./dist/ai.js"
        }
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite",
        "build": "npm run build:lib && npm run build:app",
        "build:app": "vite build --outDir dist-pages",
        "build:lib": "vite build --config vite.lib.config.ts",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview --outDir dist-pages",
        "test": "jest",
        "test:e2e": "playwright test",
        "prepublishOnly": "npm test && npm run build:lib"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "react": "^18.2.0 || ^19.0.0",
        "react-dom": "^18.2.0 || ^19.0.0"
    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.16",
        "@ai-sdk/react": "^3.0.61",
        "@hotdocx/arrowgram": "^1.0.0",
        "ai": "^6.0.59",
        "canvg": "^4.0.3",
        "diff": "^8.0.2",
        "dompurify": "^3.3.1",
        "file-saver": "^2.0.5",
        "html-to-image": "^1.11.13",
        "idb-keyval": "^6.2.2",
        "katex": "^0.16.22",
        "lucide-react": "^0.562.0",
        "mermaid": "^11.8.0",
        "pagedjs": "^0.4.3",
        "reveal.js": "^5.2.1",
        "save-svg-as-png": "^1.4.17",
        "showdown": "^2.1.0",
        "vega": "^6.1.2",
        "vega-lite": "^6.2.0",
        "zundo": "^2.3.0",
        "zustand": "^5.0.9"
    },
    "devDependencies": {
        "@playwright/test": "^1.57.0",
        "@tailwindcss/postcss": "^4.1.18",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.0.6",
        "@types/react": "^19.2.8",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.2",
        "autoprefixer": "^10.4.23",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "jest": "^30.2.0",
        "postcss": "^8.5.6",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.18",
        "ts-jest": "^29.4.6",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "vite": "^6.0.0",
        "vite-plugin-dts": "^4.5.4",
        "zod": "^4.3.5"
    }
}
