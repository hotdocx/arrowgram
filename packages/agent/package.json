{
  "name": "@hotdocx/arrowgram-agent",
  "version": "0.1.3",
  "type": "module",
  "description": "File-backed Arrowgram workspace bridge for coding-agent workflows.",
  "license": "MIT",
  "bin": {
    "arrowgram-agent": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "node --test dist/**/*.test.js",
    "test:e2e": "npm run build:lib -w @hotdocx/arrowgram-web && npm run build && playwright test -c playwright.config.ts"
  },
  "dependencies": {
    "@hotdocx/arrowgram": "^1.0.0",
    "@hotdocx/arrowgram-web": "^1.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "diff": "^8.0.2",
    "katex": "^0.16.22",
    "pagedjs": "^0.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reveal.js": "^5.2.1",
    "showdown": "^2.1.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.0.6",
    "@types/showdown": "^2.0.6",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
