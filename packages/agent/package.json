{
  "name": "@hotdocx/arrowgram-agent",
  "version": "0.1.2",
  "type": "module",
  "description": "File-backed Arrowgram workspace bridge for coding-agent workflows.",
  "license": "MIT",
  "bin": {
    "arrowgram-agent": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@hotdocx/arrowgram": "^1.0.0",
    "@hotdocx/arrowgram-web": "^1.1.0",
    "@vitejs/plugin-react": "^5.1.2",
    "katex": "^0.16.22",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "showdown": "^2.1.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/node": "^25.0.6",
    "@types/showdown": "^2.0.6",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
