{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "left": {
            "type": "number"
          },
          "top": {
            "type": "number"
          }
        },
        "required": [
          "name",
          "left",
          "top"
        ],
        "additionalProperties": false
      }
    },
    "arrows": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "label_color": {
            "type": "string"
          },
          "curve": {
            "type": "number"
          },
          "shift": {
            "type": "number"
          },
          "radius": {
            "type": "number"
          },
          "angle": {
            "type": "number"
          },
          "label_alignment": {
            "type": "string",
            "enum": [
              "over",
              "left",
              "right"
            ]
          },
          "shorten": {
            "type": "object",
            "properties": {
              "source": {
                "type": "number"
              },
              "target": {
                "type": "number"
              }
            },
            "additionalProperties": false
          },
          "style": {
            "type": "object",
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "arrow",
                  "adjunction",
                  "corner",
                  "corner_inverse"
                ]
              },
              "head": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "enum": [
                      "normal",
                      "none",
                      "epi",
                      "hook",
                      "maps_to",
                      "harpoon"
                    ]
                  },
                  "side": {
                    "type": "string",
                    "enum": [
                      "top",
                      "bottom"
                    ]
                  }
                },
                "additionalProperties": false
              },
              "tail": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "enum": [
                      "normal",
                      "none",
                      "mono",
                      "hook",
                      "maps_to"
                    ]
                  },
                  "side": {
                    "type": "string",
                    "enum": [
                      "top",
                      "bottom"
                    ]
                  }
                },
                "additionalProperties": false
              },
              "body": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "enum": [
                      "solid",
                      "dashed",
                      "dotted",
                      "squiggly",
                      "wavy",
                      "barred",
                      "double_barred",
                      "bullet_solid",
                      "bullet_hollow",
                      "none"
                    ]
                  }
                },
                "additionalProperties": false
              },
              "level": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "nodes"
  ],
  "additionalProperties": false,
  "title": "Arrowgram Specification",
  "description": "Schema for describing commutative diagrams in Arrowgram."
}
