{
    "name": "arrowgram",
    "version": "1.0.0",
    "description": "A React library for creating commutative diagrams with a declarative JSON syntax.",
    "author": "Antigravity",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/hotdocx/arrowgram.git"
    },
    "keywords": [
        "commutative-diagrams",
        "category-theory",
        "react",
        "svg",
        "quiver"
    ],
    "type": "module",
    "main": "./dist/arrowgram.umd.cjs",
    "module": "./dist/arrowgram.js",
    "exports": {
        ".": {
            "import": "./dist/arrowgram.js",
            "require": "./dist/arrowgram.umd.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "test": "vitest"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "dependencies": {
        "katex": "^0.16.22"
    },
    "devDependencies": {
        "vite": "^6.0.0",
        "vitest": "^4.0.16"
    }
}