{
    "name": "@hotdocx/arrowgram",
    "version": "1.0.0",
    "description": "A React library for creating commutative diagrams with a declarative JSON syntax.",
    "author": "Antigravity",
    "license": "MIT",
    "homepage": "https://github.com/hotdocx/arrowgram/tree/main/packages/arrowgram",
    "bugs": {
        "url": "https://github.com/hotdocx/arrowgram/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hotdocx/arrowgram.git",
        "directory": "packages/arrowgram"
    },
    "keywords": [
        "commutative-diagrams",
        "category-theory",
        "react",
        "svg",
        "quiver"
    ],
    "type": "module",
    "main": "./dist/arrowgram.umd.cjs",
    "module": "./dist/arrowgram.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/arrowgram.js",
            "require": "./dist/arrowgram.umd.cjs"
        },
        "./arrowgram.schema.json": "./arrowgram.schema.json"
    },
    "files": [
        "dist",
        "arrowgram.schema.json",
        "LICENSE"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build && npm run schema:generate",
        "schema:generate": "node ./scripts/generate_schema.mjs",
        "test": "vitest",
        "prepublishOnly": "npm test -- --run && npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "react": "^18.2.0 || ^19.0.0",
        "react-dom": "^18.2.0 || ^19.0.0"
    },
    "dependencies": {
        "katex": "^0.16.22"
    },
    "devDependencies": {
        "@types/katex": "^0.16.8",
        "@types/node": "^25.0.6",
        "@types/react": "^19.2.8",
        "@types/react-dom": "^19.2.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.4.0",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "vite": "^6.0.0",
        "vite-plugin-dts": "^4.5.3",
        "vitest": "^4.0.16",
        "zod": "^4.3.5"
    }
}
